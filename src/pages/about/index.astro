---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/navbar.astro";
---

<Layout title="Up To Infinity Incremental | About">
    <Navbar></Navbar>
    <!-- About Style -->

    <style>
        .container {
            max-width: 900px;
            margin: 0 auto;
            margin-top: 25px;
            padding: 40px 20px;
            text-align: center;
            background: #fff1;
            border-radius: 16px;
            box-shadow: 0 8px 32px #000b;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            transition: background-color 0.3s ease, backdrop-filter 0.3s ease;
            box-sizing: border-box;
        }

        .container:hover {
            background: transparent;
            backdrop-filter: blur(0)
        }

        .container-title{
            font-size: 64px;
            font-weight: 700;
            text-shadow: 2px 2px 8px #000e;
            margin: 20px 0;
            transition: color 0.3s ease;
            color: inherit;
            font-family: inherit;
        }

        .container-info{
            font-size: 28px;
            color: inherit;
            margin: 10px 0 30px 0;
            text-shadow: 1px 1px 6px #000c;
            font-family: inherit;
        }

        .container-description{
            font-size: 22px;
            color: inherit;
            margin: 10px 0;
            text-shadow: 1px 1px 5px #000b;
            font-family: inherit;
        }

        .company{
            color: #fff;
            text-decoration: none;
            transition: color 0.3s ease, border-bottom 0.3s ease;
        }

        .company:hover{
            color: #8a5be2;
            border-bottom: 2px solid #8a5be2;
        }

        .company:active{
            color: #ff00bf;
            border-bottom: 2px solid #ff00bf;
        }

        .company::selection{
            background: #bbb;
        }

    </style>


    <main role="main">
        <div class="container">
            <h1 class="container-title" role="heading">Qronex Studio</h1>
            <p class="container-info" role="heading" aria-level="Up To Infinity Incremental">Up To Infinity Incremental</p>
            <p class="container-description" role="contentinfo">Is created by <a href="http://qronexstudiosai.work.gd" target="_blank" class="company">Qronex Studio</a>
